---
import Footer from "../components/Footer.astro";
import Layout from "../Layouts/layout.astro";


---

<Layout title="Output">
	<section id="hero">
		<div class="hero-content">

			<a href="https://hackclub.com/" class="hc-flag"><img src="https://assets.hackclub.com/flag-orpheus-top.svg" alt="Hack Club"/></a>

			<h1 class="blue">Output</h1>
			<p>Build a website that controls real-world hardware and get prizes like RPi Zero 2W, LED matrix, stickers & more!</p>
			<a href="#about" class="hero-cta">Get Started →</a>
		</div>
		<div class="hero-visual">
		</div>
	</section>

	<section id="about">
		<h2 class="red">What is Output?</h2>
		<p>Output is a You Ship We Ship where You build a website that interacts with real-world hardware. We send you the hardware to make it work.</p>
		<p><strong>Digital → Physical:</strong> Your website sends commands to a Raspberry Pi, which controls LEDs, printers, lights, motors — anything you can imagine!</p>
	</section>

	<section id="steps">
		<h2 class="green">How to Build</h2>
		<div class="steps">

			<div class="step">
				<h3>1. Plan Your Project</h3>
				<p>What will your website control? A printer? LED matrix? Something custom?</p>
			</div>

			<div class="step">
				<h3>2. Build Your Website</h3>
				<p>Create a website that controls your hardware safely and let people interact with your creation from anywhere in the world.</p>
			</div>

			<div class="step">
				<h3>3. Test & Submit</h3>
				<p>Get it working, then submit your project for review!</p>
			</div>

			<div class="step">
				<h3>4. Get Your Hardware</h3>
				<p>Once approved, we'll send you a RPi Zero 2W, LED matrix, stickers, and more!</p>
			</div>
		</div>
	</section>

	<section id="example">
		<h2 class="pink">See It In Action</h2>
		<div class="example-showcase">
			<div class="example-project">
				<h3>print.lukasreis.com</h3>
				<p>Leave a message on the website → it gets printed to a physical printer!</p>
				<p><a target="_blank" href="https://print.lukasreis.com">Try it →</a></p>
			</div>
		</div>
	</section>

	<section id="faq">
		<h2 class="purple">Questions?</h2>
		<details class="">
			<summary class="prevent-select">Q: Who can participate?</summary>
			<p>A: Anyone 13-18 years old!</p>
		</details>

		<details>
			<summary class="prevent-select">Q: Is this free?</summary>
			<p>A: Yes this program is being run by <a href="https://hackclub.com">Hack Club</a>, a nonprofit that makes programs by teenagers for teenagers. </p>
		</details>

		<details>
			<summary class="prevent-select">Q: What hardware do I need to start?</summary>
			<p>A: You just need a computer and internet. We'll send you the RPi, LED matrix, stickers, and more after your project is approved!</p>
		</details>

		<details>
			<summary class="prevent-select">Q: What if I'm stuck?</summary>
			<p>A: Join the Hack Club Slack and ask in the Output channel. We're here to help!</p>
		</details>

		<details>
			<summary class="prevent-select">Q: Can I use any programming language?</summary>
			<p>A: Yes! Any language that can communicate with your hardware works — Python, JavaScript, Go, anything</p>
		</details>

		<h3 style="margin-top: 2rem;">Need more help?</h3>
		<p><strong>Join the Hack Club Slack:</strong> <a href="https://hackclub.enterprise.slack.com/archives/C0AMRN954BD" target="_blank">join.slack.com</a></p>
		<p>Ask questions in the <strong>#output</strong> channel!</p>
	</section>

	<section id="submit">
		<h2 class="yellow">Ready? Submit Your Project</h2>
	</section>

	<hr>

	<Footer />

</Layout>

<style>
	.prevent-select {
		-webkit-user-select: none;
		-ms-user-select: none;
		user-select: none;
	}

	.blue {
		color: #08B2E3;
	}

	.red {
		color: #EE6352;
	}

	.green {
		color: #57A773;
	}

	.pink {
		color: #FF88E7;
	}

	.purple {
		color: #7862BA;
	}

	.yellow {
		color: #FFC300;
	}

	/* ---- HERO ---- */
	#hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		margin-bottom: 4rem;
		margin-left: calc(-1 * max(calc((100vw - 800px) / 2), 20px));
		margin-right: calc(-1 * max(calc((100vw - 800px) / 2), 20px));
		padding: 4rem 2rem;
	}

	.hc-flag {
		position: fixed;
		top: 0;
		left: 10px;
		width: 180px;
		z-index: 999;
		border: 0;
	}

	.hc-flag img {
		width: 100%;
		display: block;
	}

	.hero-content {
		position: relative;
		z-index: 1;
	}

	#hero h1 {
		font-size: clamp(4.5rem, 12vw, 7rem);
	}

	#hero p {
		font-size: 1.2rem;
		max-width: 500px;
		margin: 0 auto 2rem;
	}

	.hero-cta {
		display: inline-block;
		background: #08B2E3;
		color: #fff;
		text-decoration: none;
		padding: 0.75rem 2rem;
		border-radius: 8px;
		font-size: 1.1rem;
		font-weight: 600;
		transition: transform 0.2s, box-shadow 0.2s;
	}

	.hero-cta:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(8, 178, 227, 0.3);
	}

	.hero-visual {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
	}

	@media (max-width: 600px) {
		.hc-flag {
			width: 100px;
		}
	}
</style>
