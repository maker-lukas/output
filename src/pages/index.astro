---
import Footer from "../components/Footer.astro";
import Layout from "../Layouts/layout.astro";


---

<Layout title="Output">
	<section id="hero">
		<div class="hero-software">
			<div class="software-item software-item-1">
				<img src="/images/terminal_text.svg" alt="Terminal" class="software-icon" />
			</div>
			<div class="software-item software-item-2">
				<img src="/images/vscode.svg" alt="VS Code" class="software-icon-small" />
			</div>
			<div class="software-item software-item-3">
				<img src="/images/python-logo.png" alt="Python" class="software-icon-small" />
			</div>
		</div>

		<div class="hero-content">

			<a href="https://hackclub.com/" class="hc-flag"><img src="https://assets.hackclub.com/flag-orpheus-top.svg" alt="Hack Club"/></a>

			<svg class="arrow-svg" viewBox="0 0 800 200" preserveAspectRatio="xMidYMid meet">
				<defs>
					<marker id="arrowhead" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
						<polygon points="0 0, 10 3, 0 6" fill="#08B2E3" />
					</marker>
				</defs>
				<path d="M 50 150 Q 400 30 750 150" stroke="#08B2E3" stroke-width="4" fill="none" marker-end="url(#arrowhead)" stroke-linecap="round" />
			</svg>

			<h1 class="blue">Output</h1>
			<p>Build a website that controls real-world hardware and we'll send you parts like RPi Zero 2Ws, LED matrices, stickers & more to make it happen!</p>
			<a href="#about" class="hero-cta">Get Started →</a>
		</div>

		<div class="hero-hardware">
			<div class="hardware-item">
				<img src="/images/brother_dcp.png" alt="Printer" class="hardware-icon" />
			</div>
			<div class="hardware-item">
				<img src="/images/zero2w.png" alt="Raspberry Pi Zero 2W" class="hardware-icon" />
			</div>
			<div class="hardware-item">
				<img src="/images/led_matrix.png" alt="LED Matrix" class="hardware-icon" />
			</div>
		</div>
	</section>

	<section id="about">
		<h2 class="red">What is Output?</h2>
		<p>Output is a You Ship We Ship where You build a website that interacts with real-world hardware. We send you the hardware to make it work.</p>
		<p><strong>Digital → Physical:</strong> Your website sends commands to a Raspberry Pi, which controls LEDs, printers, lights, motors, anything you can imagine!</p>
	</section>

	<section id="steps">
		<h2 class="green">How to Build</h2>
		<div class="steps">

			<div class="step-card">
				<h3>1. Plan Your Project</h3>
				<p>What will your website control? A printer? LED matrix? Something custom?</p>
			</div>

			<div class="step-card">
				<h3>2. Build Your Website</h3>
				<p>Create a website that controls your hardware safely and let people interact with your creation from anywhere in the world.</p>
			</div>

			<div class="step-card">
				<h3>3. Test & Submit</h3>
				<p>Get it working, then submit your project for review!</p>
			</div>

			<div class="step-card">
				<h3>4. Get Your Hardware</h3>
				<p>Once approved, we'll send you the hardware your project needs like a RPi Zero 2W, LED matrix, stickers & more!</p>
			</div>
		</div>
	</section>

	<section id="example">
		<h2 class="pink">Cool projects</h2>
		<div class="example-cards">
			<div class="example-card">
				<h3>print.lukasreis.com</h3>
				<p>Leave a message on the website → it gets printed to a physical printer!</p>
				<p><a target="_blank" href="https://print.lukasreis.com">Try it →</a></p>
			</div>
			<div class="example-card">
				<h3>CompilerFax</h3>
				<p>Fax your C code to a Raspberry Pi → it compiles it and faxes back the result!</p>
				<p><a target="_blank" href="https://github.com/lexbailey/compilerfax">View project →</a></p>
			</div>
			<div class="example-card">
				<h3>inkday</h3>
				<p>Upload images via a website calendar → they show up on a physical e-ink display each day!</p>
				<p><a target="_blank" href="https://github.com/jflessau/inkday">View project →</a></p>
			</div>
		</div>
	</section>

	<section id="faq">
		<h2 class="purple">FAQ</h2>
		<details class="faq-item">
			<summary class="prevent-select">Q: Who can participate?</summary>
			<p>A: Any teenager between 13 and 18 years old, anywhere in the world!</p>
		</details>

		<details class="faq-item">
			<summary class="prevent-select">Q: Is this free?</summary>
			<p>A: Completely free! This program is run by <a href="https://hackclub.com">Hack Club</a>, a nonprofit that builds programs by teenagers, for teenagers.</p>
		</details>

		<details class="faq-item">
			<summary class="prevent-select">Q: What hardware do I need to start?</summary>
			<p>A: Just a computer and internet access. You build and test your website first, and once approved we ship you the hardware your project needs like a RPi Zero 2W, LED matrix, stickers & more.</p>
		</details>

		<details class="faq-item">
			<summary class="prevent-select">Q: Can I use any programming language?</summary>
			<p>A: Yes! Python, JavaScript, Go, Rust... any language that can talk to hardware works. Use whatever you want.</p>
		</details>

		<h3 style="margin-top: 2rem;">Need more help?</h3>
		<p>Join the <a href="https://hackclub.enterprise.slack.com/archives/C0AMRN954BD" target="_blank">Hack Club Slack</a> and ask in the <strong>#output</strong> channel!</p>
	</section>

	<section id="submit">
		<h2 class="yellow">Submit Your Project</h2>
		<p><strong>Submissions are currently closed, opening soon!</strong></p>
	</section>

	<hr>

	<Footer />

</Layout>

<style>

	hr {
		border: 1px solid #08B2E3;
	}

	.prevent-select {
		-webkit-user-select: none;
		-ms-user-select: none;
		user-select: none;
	}

	.blue {
		color: #08B2E3;
	}

	.red {
		color: #EE6352;
	}

	.green {
		color: #57A773;
	}

	.pink {
		color: #FF88E7;
	}

	.purple {
		color: #7862BA;
	}

	.yellow {
		color: #FFC300;
	}

	#hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: space-between;
		text-align: center;
		margin-bottom: 4rem;
		margin-left: calc(-1 * max(calc((100vw - 800px) / 2), 20px));
		margin-right: calc(-1 * max(calc((100vw - 800px) / 2), 20px));
		padding: 4rem 2rem;
		gap: 2rem;
	}

	.hero-software {
		flex: 1;
		height: 100%;
		min-height: 500px;
	}

	.hero-hardware {
		flex: 1;
		height: 100%;
		min-height: 500px;
	}

	.hardware-item {
		position: absolute;
		transition: transform 0.3s ease;
	}

	.software-item {
		position: absolute;
		transition: transform 0.3s ease;
	}

	.software-item-1 {
		top: 15%;
		left: 3%;
		transform: rotate(8deg);
	}

	.software-item-1:hover {
		transform: rotate(10deg) scale(1.25);
	}

	.software-item-2 {
		top: 55%;
		left: 5%;
		transform: rotate(-15deg);
	}

	.software-item-2:hover {
		transform: rotate(-20deg) scale(1.2);
	}

	.software-item-3 {
		bottom: 15%;
		left: 8%;
		transform: rotate(12deg);
	}

	.software-item-3:hover {
		transform: rotate(15deg) scale(1.18);
	}

	.hardware-item:nth-child(1) {
		top: 8%;
		right: 5%;
		transform: rotate(5deg);
	}

	.hardware-item:nth-child(1):hover {
		transform: rotate(8deg) scale(1.2);
	}

	.hardware-item:nth-child(2) {
		bottom: 8%;
		right: 8%;
		transform: rotate(-20deg);
	}

	.hardware-item:nth-child(2):hover {
		transform: rotate(-22deg) scale(1.15);
	}

	.hardware-item:nth-child(3) {
		top: 48%;
		right: 3%;
		transform: rotate(18deg);
	}

	.hardware-item:nth-child(3):hover {
		transform: rotate(20deg) scale(1.22);
	}

	.software-icon {
		width: 180px;
		height: 180px;
		object-fit: contain;
		filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.15));
	}

	.software-icon-small {
		width: 120px;
		height: 120px;
		object-fit: contain;
		filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.15));
	}

	.hardware-icon {
		width: 200px;
		height: 200px;
		object-fit: contain;
		filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.15));
	}

	.hc-flag {
		position: fixed;
		top: 0;
		left: 10px;
		width: 180px;
		z-index: 999;
		border: 0;
	}

	.hc-flag img {
		width: 100%;
		display: block;
	}

	.hero-content {
		position: relative;
		z-index: 1;
	}

	.arrow-svg {
		width: 100%;
		max-width: 900px;
		height: 200px;
		margin-bottom: 2rem;
	}

	#hero h1 {
		font-family: 'Bungee', cursive;
		font-size: clamp(4.5rem, 12vw, 7rem);
	}

	#hero p {
		font-size: 1.2rem;
		max-width: 500px;
		margin: 0 auto 2rem;
	}

	.hero-cta {
		display: inline-block;
		background: #08B2E3;
		color: #fff;
		text-decoration: none;
		padding: 0.75rem 2rem;
		border-radius: 8px;
		font-size: 1.1rem;
		font-weight: 600;

		transition: transform 0.2s ease;
	}

	.hero-cta:hover {
		transform: rotate(5deg) scale(1.1);
	}

	.hero-visual {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
	}

	:global(body) {
		background-image: radial-gradient(circle, rgba(8, 178, 227, 0.5) 1px, transparent 1px);
		background-size: 25px 25px;
	}

	@media (max-width: 900px) {
		.software-item-1,
		.hardware-item:nth-child(3) {
			display: none;
		}

		#hero {
			flex-direction: column;
			justify-content: center;
			gap: 1.5rem;
			min-height: auto;
			padding: 2rem 1rem;
		}

		.hero-software,
		.hero-hardware {
			position: relative;
			height: auto;
			min-height: 150px;
			flex: none;
			width: 100%;
			display: flex;
			align-items: center;
			justify-content: center;
			flex-wrap: wrap;
		}

		.software-item,
		.hardware-item {
			position: relative !important;
			top: auto !important;
			left: auto !important;
			right: auto !important;
			bottom: auto !important;
			margin: 0.5rem;
		}

		.arrow-svg {
			display: none;
		}
	}

	#steps {
		padding: 2rem 0;
	}

	.steps {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2rem;
		margin-top: 2rem;
		max-width: 800px;
		margin-left: auto;
		margin-right: auto;
	}

	.step-card {
		background: #ffffff;
		border: 1px solid #e0e0e0;
		border-left: 4px solid #57A773;
		padding: 2rem;
		border-radius: 8px;
		height: 100%;
		display: flex;
		flex-direction: column;
	}

	.faq-item {
		background: #ffffff;
		border: 1px solid #e0e0e0;
		border-left: 4px solid #7862BA;
		padding: 1.5ch;
		border-radius: 8px;
		margin-bottom: 1ch;
		display: block;
	}

	.faq-item summary {
		cursor: pointer;
		font-weight: 600;
	}

	.faq-item p {
		margin: 1rem 0 0 0;
	}

	.step-card h3 {
		margin: 0 0 0.75rem 0;
	}

	.step-card p {
		margin: 0;
		flex-grow: 1;
	}

	.example-cards {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
		margin-top: 2rem;
	}

	.example-card {
		background: #ffffff;
		border: 1px solid #e0e0e0;
		border-left: 4px solid #FF88E7;
		padding: 2rem;
		border-radius: 8px;
		display: flex;
		flex-direction: column;
	}

	.example-card h3 {
		margin: 0 0 0.75rem 0;
	}

	.example-card p {
		margin: 0 0 0.75rem 0;
	}

	.example-card p:nth-child(2) {
		flex-grow: 1;
	}

	.example-card p:last-child {
		margin: 0;
	}

	@media (max-width: 600px) {
		.hc-flag {
			display: none;
		}

		#hero {
			padding: 2rem 1rem;
		}

		#hero p {
			font-size: 1rem;
		}

		#hero h1 {
			font-size: clamp(2.5rem, 8vw, 4rem);
		}

		.steps {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.example-cards {
			grid-template-columns: 1fr;
		}
	}
</style>
